  vineyard:            'rgba(190,170,80,0.60)',
  allotments:          'rgba(150,220,110,0.55)',
  greenhouse_horticulture: 'rgba(180,240,160,0.55)',
  meadow:              'rgba(140,220,120,0.50)',
  plant_nursery:       'rgba(120,200,100,0.50)',
  paddy:               'rgba(100,200,160,0.55)',
  _default:            'rgba(150,210,100,0.45)',
};
const FARM_COLORS_LIGHT = {
  farmland:            'rgba(200,240,140,0.65)',
  farm:                'rgba(200,240,140,0.65)',
  farmyard:            'rgba(230,230,130,0.60)',
  orchard:             'rgba(170,240,120,0.65)',
  vineyard:            'rgba(230,210,110,0.65)',
  allotments:          'rgba(190,250,150,0.60)',
  greenhouse_horticulture: 'rgba(210,255,190,0.65)',
  meadow:              'rgba(180,250,160,0.55)',
  plant_nursery:       'rgba(160,240,140,0.55)',
  paddy:               'rgba(140,240,200,0.60)',
  _default:            'rgba(190,245,140,0.50)',
};
const FARM_LABELS = {
  farmland:'農地', farm:'農地', farmyard:'農場',
  orchard:'果樹園', vineyard:'ブドウ園', allotments:'市民農園',
  greenhouse_horticulture:'温室栽培', meadow:'牧草地',
  plant_nursery:'苗圃', paddy:'水田',
};

function drawFarm() {
  ctx.shadowBlur=0;
  const cmap=state.bgDark?FARM_COLORS_DARK:FARM_COLORS_LIGHT;
  for(const poly of state.farmPolys){
    if(!poly.rings||!poly.rings[0]||poly.rings[0].length<3) continue;
    ctx.fillStyle=cmap[poly.type]||cmap._default;
    ctx.beginPath();
    const outer=poly.rings[0];
    ctx.moveTo(outer[0].x,outer[0].y);
    for(let i=1;i<outer.length;i++) ctx.lineTo(outer[i].x,outer[i].y);
    ctx.closePath();
    for(let h=1;h<poly.rings.length;h++){
      const hole=poly.rings[h];
      ctx.moveTo(hole[0].x,hole[0].y);
      for(let i=1;i<hole.length;i++) ctx.lineTo(hole[i].x,hole[i].y);
      ctx.closePath();
    }
    ctx.fill('evenodd');
  }
}

function parseFarmPolys(data,bb){
  const nodes={};
  for(const el of data.elements) if(el.type==='node') nodes[el.id]={lat:el.lat,lon:el.lon};
  const scale=getScale(bb); const polys=[];
  for(const el of data.elements){
    if(el.type!=='way') continue;
    const pts=[];
    for(const nid of el.nodes){const n=nodes[nid];if(n)pts.push(project(n.lat,n.lon,bb,scale));}
    if(pts.length<3) continue;
    if(el.nodes[0]!==el.nodes[el.nodes.length-1]) continue;
    const tags=el.tags||{};
    const type=tags.landuse||'_default';
    polys.push({type,rings:[pts]});
  }
  return polys;
}

const FARM_QUERY_TYPES = 'farmland|farm|farmyard|orchard|vineyard|allotments|greenhouse_horticulture|meadow|plant_nursery|paddy';

async function fetchFarm(){
  const bb=state.bb; const {minLat:s,minLon:w,maxLat:n,maxLon:e}=bb;
  showLoading(state.cityName,'農地データを取得中…',10);
  try{
    const q=`[out:json][timeout:90];way["landuse"~"${FARM_QUERY_TYPES}"](${s},${w},${n},${e});(._;>;);out body;`;
    setProgress(30);
    const data=await overpassFetch(q);
    setProgress(70);
    state.farmPolys=parseFarmPolys(data,bb);
    setProgress(100);
    updateInfoPanel(); updateLegends(); draw();
    toast(`農地 ${state.farmPolys.length.toLocaleString()} 区画`);
  }catch(err){toast('農地エラー: '+err.message,5000);}
  finally{hideLoading();}
}

async function fetchFarmSilent(bb){
  const {minLat:s,minLon:w,maxLat:n,maxLon:e}=bb;
  const q=`[out:json][timeout:90];way["landuse"~"${FARM_QUERY_TYPES}"](${s},${w},${n},${e});(._;>;);out body;`;
  state.farmPolys=parseFarmPolys(await overpassFetch(q),bb);
}

function buildFarmLegend(){
  const container=document.getElementById('farm-legend-items');
  container.innerHTML='';
  const cmap=state.bgDark?FARM_COLORS_DARK:FARM_COLORS_LIGHT;
  const seen=new Set();
  for(const poly of state.farmPolys){
    if(seen.has(poly.type)) continue; seen.add(poly.type);
    const label=FARM_LABELS[poly.type]||poly.type;
    const color=cmap[poly.type]||cmap._default;
    const item=document.createElement('div');
    item.className='land-legend-item';
    item.innerHTML=`<div class="land-legend-dot" style="background:${color}"></div><span>${label}</span>`;
    container.appendChild(item);
    if(seen.size>=6) break;
  }
}

draw();
</script>
