async function loadCity(item) {
  const name=item.display_name.split(',')[0];
  const [s,n,w,e]=item.boundingbox.map(Number);
  const bb={minLat:s,maxLat:n,minLon:w,maxLon:e};
  document.getElementById('panel').classList.add('hidden');
  showLoading(name,'道路データを取得中…',5);
  try {
    state.roads=await fetchRoads(bb); setProgress(40);
    state.rivers=[]; state.elevGrid=null; state.landPolys=[]; state.farmPolys=[];
    state.cityName=name; state.bb=bb;
    state.zoom=1; state.panX=0; state.panY=0;
    setProgress(60);

    // ON中のレイヤーを並列取得
    const tasks=[];
    if(state.layers.river) tasks.push(fetchAndParseRiversSilent(bb));
    if(state.layers.elev)  tasks.push(fetchElevationSilent(bb));
    if(state.layers.land)  tasks.push(fetchLanduseSilent(bb));
    if(state.layers.farm)  tasks.push(fetchFarmSilent(bb));
    if(tasks.length) await Promise.all(tasks);

    setProgress(100); draw(); showPostUI(name);
  } catch(err){
    toast('エラー: '+err.message,5000);
    document.getElementById('panel').classList.remove('hidden');
  } finally { hideLoading(); }
}

