// ══════════════════════════════════════════
//  Overpass fetch
// ══════════════════════════════════════════
async function overpassFetch(query) {
  const r=await fetch('https://overpass-api.de/api/interpreter',{method:'POST',body:query});
  if(!r.ok) throw new Error('Overpass HTTP '+r.status);
  return r.json();
}

function parseWays(data,bb) {
  const nodes={};
  for(const el of data.elements) if(el.type==='node') nodes[el.id]={lat:el.lat,lon:el.lon};
  const scale=getScale(bb); const segs=[];
  for(const el of data.elements){
    if(el.type!=='way') continue;
    const pts=[];
    for(const nid of el.nodes){const n=nodes[nid];if(n)pts.push(project(n.lat,n.lon,bb,scale));}
    if(pts.length>=2) segs.push(pts);
  }
  return segs;
}

// ── 道路 ──
async function fetchRoads(bb) {
  const {minLat:s,minLon:w,maxLat:n,maxLon:e}=bb;
  const q=`[out:json][timeout:60];way["highway"](${s},${w},${n},${e});(._;>;);out body;`;
  return parseWays(await overpassFetch(q), bb);
}

