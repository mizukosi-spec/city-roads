<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>まちの道路を描く</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Zen+Kaku+Gothic+New:wght@300;400;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
  :root {
    --bg:#0a0a0f; --surface2:#1a1a28; --border:rgba(255,255,255,.08);
    --accent:#7c6aff; --accent2:#ff6a9e; --text:#e8e8f0;
    --text-muted:rgba(232,232,240,.45); --road:#c8c0ff; --glow:rgba(124,106,255,.3);
  }
  html,body { width:100%;height:100%;background:var(--bg);color:var(--text);font-family:'Noto Sans JP',sans-serif;overflow:hidden; }
  #canvas { position:fixed;inset:0;width:100%;height:100%; }
  #ui     { position:fixed;inset:0;pointer-events:none;z-index:10; }

  /* ── CENTER PANEL ── */
  #panel {
    position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    width:min(420px,92vw);pointer-events:all;transition:opacity .5s,transform .5s;
  }
  #panel.hidden { opacity:0;pointer-events:none;transform:translate(-50%,-60%); }
  .panel-title {
    font-family:'Zen Kaku Gothic New',sans-serif;font-size:clamp(1.4rem,4vw,2rem);
    font-weight:700;text-align:center;letter-spacing:.04em;margin-bottom:.3em;
    background:linear-gradient(135deg,var(--road),var(--accent2));
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  }
  .panel-sub { text-align:center;color:var(--text-muted);font-size:.82rem;margin-bottom:1.6rem;line-height:1.6; }
  .search-wrap { position:relative; }
  #search {
    width:100%;padding:.85rem 3rem .85rem 1.1rem;
    background:var(--surface2);border:1px solid var(--border);border-radius:12px;
    color:var(--text);font-family:'Noto Sans JP',sans-serif;font-size:1rem;
    outline:none;transition:border-color .25s,box-shadow .25s;
  }
  #search:focus { border-color:var(--accent);box-shadow:0 0 0 3px var(--glow); }
  #search::placeholder { color:var(--text-muted); }
  .search-btn {
    position:absolute;right:.6rem;top:50%;transform:translateY(-50%);
    background:none;border:none;cursor:pointer;color:var(--accent);
    font-size:1.3rem;padding:.3rem;line-height:1;transition:color .2s;z-index:5;
  }
  .search-btn:hover { color:var(--accent2); }
  #suggestions {
    position:absolute;top:calc(100% + 6px);left:0;right:0;
    background:var(--surface2);border:1px solid var(--border);border-radius:10px;
    overflow:hidden;z-index:100;max-height:260px;overflow-y:auto;
    box-shadow:0 8px 32px rgba(0,0,0,.5);display:none;
  }
  .suggestion-item {
    padding:.65rem 1rem;cursor:pointer;font-size:.88rem;color:var(--text);
    border-bottom:1px solid var(--border);transition:background .15s;
    display:flex;flex-direction:column;gap:.15rem;
  }
  .suggestion-item:last-child { border-bottom:none; }
  .suggestion-item:hover { background:rgba(124,106,255,.15); }
  .suggestion-name { font-weight:500; }
  .suggestion-detail { font-size:.75rem;color:var(--text-muted); }

  /* ── MINI SEARCH ── */
  #mini-search-wrap {
    position:absolute;top:1rem;left:1rem;
    pointer-events:all;opacity:0;transition:opacity .4s;
  }
  #mini-search-wrap.visible { opacity:1; }
  #mini-search {
    width:220px;padding:.55rem .9rem;
    background:var(--surface2);border:1px solid var(--border);border-radius:10px;
    color:var(--text);font-family:'Noto Sans JP',sans-serif;font-size:.85rem;outline:none;
  }
  #mini-search::placeholder { color:var(--text-muted); }
  #mini-suggestions {
    position:absolute;top:calc(100% + 4px);left:0;width:280px;
    background:var(--surface2);border:1px solid var(--border);border-radius:10px;
    overflow:hidden;z-index:200;max-height:220px;overflow-y:auto;
    box-shadow:0 8px 32px rgba(0,0,0,.5);display:none;
  }

  /* ── TOOLBAR ── */
  #toolbar {
    position:absolute;top:1rem;right:1rem;
    display:flex;flex-direction:column;gap:.5rem;
    pointer-events:all;opacity:0;transition:opacity .4s;
    max-width:220px;
  }
  #toolbar.visible { opacity:1; }
  .tool-btn {
    background:var(--surface2);border:1px solid var(--border);border-radius:10px;
    color:var(--text);padding:.55rem .9rem;font-family:'Noto Sans JP',sans-serif;
    font-size:.8rem;cursor:pointer;display:flex;align-items:center;gap:.4rem;
    transition:background .2s,border-color .2s;white-space:nowrap;
  }
  .tool-btn:hover { background:rgba(124,106,255,.2);border-color:var(--accent); }

  /* ── LAYER TOGGLES（複数同時ON可能） ── */
  #layer-section {
    background:var(--surface2);border:1px solid var(--border);
    border-radius:10px;padding:.5rem .6rem;display:flex;flex-direction:column;gap:.3rem;
  }
  .layer-section-title {
    font-size:.7rem;color:var(--text-muted);letter-spacing:.05em;margin-bottom:.1rem;padding:0 .2rem;
  }
  .layer-toggle {
    display:flex;align-items:center;gap:.5rem;
    padding:.35rem .5rem;border-radius:7px;cursor:pointer;
    border:1px solid transparent;transition:all .2s;
    font-size:.78rem;color:var(--text-muted);font-family:'Noto Sans JP',sans-serif;
    background:none;text-align:left;width:100%;
  }
  .layer-toggle:hover { background:rgba(255,255,255,.05);color:var(--text); }
  .layer-toggle.on { color:var(--text); }
  .layer-toggle .toggle-dot {
    width:10px;height:10px;border-radius:50%;border:2px solid currentColor;
    flex-shrink:0;transition:background .2s;
  }
  .layer-toggle.on .toggle-dot { background:currentColor; }
  .layer-toggle[data-layer="road"]  { --lc:#c8c0ff; }
  .layer-toggle[data-layer="river"] { --lc:#60b0ff; }
  .layer-toggle[data-layer="elev"]  { --lc:#64ffb4; }
  .layer-toggle[data-layer="land"]  { --lc:#ffd97d; }
  .layer-toggle[data-layer="farm"]  { --lc:#a8d96e; }
  .layer-toggle.on { color:var(--lc);border-color:color-mix(in srgb,var(--lc) 40%,transparent); }

  /* ── COLOR ROW ── */
  #color-row {
    display:flex;gap:.4rem;flex-wrap:wrap;
    background:var(--surface2);border:1px solid var(--border);
    border-radius:10px;padding:.5rem .7rem;
  }
  .swatch {
    width:20px;height:20px;border-radius:50%;cursor:pointer;
    border:2px solid transparent;transition:transform .15s,border-color .15s;
  }
  .swatch:hover { transform:scale(1.2); }
  .swatch.active { border-color:#fff; }

  /* ── LEGENDS ── */
  #legends {
    position:absolute;bottom:1rem;left:50%;transform:translateX(-50%);
    display:flex;flex-direction:column;gap:.4rem;align-items:center;
    pointer-events:none;
  }
  .legend-box {
    background:var(--surface2);border:1px solid var(--border);border-radius:10px;
    padding:.45rem .8rem;font-size:.72rem;color:var(--text-muted);
    display:none;align-items:center;gap:.5rem;
  }
  .legend-box.visible { display:flex; }
  #elev-gradient {
    width:100px;height:8px;border-radius:4px;
    background:linear-gradient(to right,#0d1b6e,#1e6b9e,#3db89e,#a8d96e,#f5e642,#e07b20,#c0392b,#f0e6dc);
  }
  #land-legend-items {
    display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;
  }
  .land-legend-item { display:flex;align-items:center;gap:.25rem; }
  .land-legend-dot { width:10px;height:10px;border-radius:2px;flex-shrink:0; }

  /* ── CITY LABEL ── */
  #city-label {
    position:absolute;bottom:3.5rem;left:50%;transform:translateX(-50%);
    font-family:'Zen Kaku Gothic New',sans-serif;font-size:clamp(1.8rem,5vw,3.2rem);
    font-weight:700;letter-spacing:.06em;color:rgba(232,232,240,.1);
    pointer-events:none;white-space:nowrap;opacity:0;transition:opacity .6s;
  }
  #city-label.visible { opacity:1; }

  /* ── INFO ── */
  #info {
    position:absolute;bottom:1rem;right:1rem;
    background:var(--surface2);border:1px solid var(--border);border-radius:10px;
    padding:.6rem .9rem;font-size:.75rem;color:var(--text-muted);line-height:1.8;
    pointer-events:none;opacity:0;transition:opacity .4s;
  }
  #info.visible { opacity:1; }
  #info strong { color:var(--text); }

  /* ── LOADING ── */
  #loading {
    position:fixed;inset:0;display:flex;flex-direction:column;
    align-items:center;justify-content:center;gap:1rem;
    background:rgba(10,10,15,.85);backdrop-filter:blur(6px);
    z-index:50;opacity:0;pointer-events:none;transition:opacity .3s;
  }
  #loading.visible { opacity:1;pointer-events:all; }
  .spinner {
    width:48px;height:48px;border:3px solid var(--border);
    border-top-color:var(--accent);border-radius:50%;animation:spin 1s linear infinite;
  }
  @keyframes spin { to { transform:rotate(360deg); } }
  .loading-city {
    font-family:'Zen Kaku Gothic New',sans-serif;font-size:1.3rem;
    background:linear-gradient(135deg,var(--road),var(--accent2));
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  }
  .loading-text { font-size:.9rem;color:var(--text-muted); }
  #loading-progress { width:200px;height:4px;background:var(--border);border-radius:2px;overflow:hidden; }
  #loading-bar { height:100%;width:0%;background:var(--accent);border-radius:2px;transition:width .3s; }

  /* ── TOAST ── */
  #toast {
    position:fixed;bottom:5rem;left:50%;transform:translateX(-50%);
    background:var(--surface2);border:1px solid var(--border);border-radius:20px;
    padding:.5rem 1.2rem;font-size:.82rem;color:var(--text);z-index:200;
    opacity:0;transition:opacity .3s;pointer-events:none;
  }
  #toast.show { opacity:1; }

  ::-webkit-scrollbar { width:5px; }
  ::-webkit-scrollbar-track { background:transparent; }
  ::-webkit-scrollbar-thumb { background:var(--border);border-radius:3px; }
</style>
</head>
<body>
<canvas id="canvas"></canvas>

<div id="loading">
  <div class="spinner"></div>
  <div class="loading-city" id="loading-city"></div>
  <div class="loading-text" id="loading-msg">データを取得中…</div>
  <div id="loading-progress"><div id="loading-bar"></div></div>
</div>

<div id="ui">
  <div id="panel">
    <h1 class="panel-title">まちの道路を描く</h1>
    <p class="panel-sub">OpenStreetMapのデータを使って<br>都市の道路・河川・標高・土地利用・農地を描画します</p>
    <div class="search-wrap">
      <input id="search" type="text" placeholder="都市名を入力（名古屋、大阪、Tokyo…）" autocomplete="off" spellcheck="false">
      <button class="search-btn" id="search-go" title="検索">🔍</button>
      <div id="suggestions"></div>
    </div>
  </div>

  <div id="mini-search-wrap">
    <input id="mini-search" type="text" placeholder="別の都市を検索…" autocomplete="off" spellcheck="false">
    <div id="mini-suggestions"></div>
  </div>

  <div id="toolbar">
    <!-- Layer toggles -->
    <div id="layer-section">
      <div class="layer-section-title">レイヤー（複数選択可）</div>
      <button class="layer-toggle on" data-layer="road">
        <span class="toggle-dot"></span>🛣️ 道路
      </button>
      <button class="layer-toggle" data-layer="land">
        <span class="toggle-dot"></span>🏘️ 土地利用
      </button>
      <button class="layer-toggle" data-layer="elev">
        <span class="toggle-dot"></span>🏔️ 標高
      </button>
      <button class="layer-toggle" data-layer="farm">
        <span class="toggle-dot"></span>🌾 農地
      </button>
      <button class="layer-toggle" data-layer="river">
        <span class="toggle-dot"></span>🌊 河川
      </button>
    </div>
    <div id="color-row"></div>
    <button class="tool-btn" id="btn-download">💾 PNG保存</button>
    <button class="tool-btn" id="btn-reset">🔄 リセット</button>
    <button class="tool-btn" id="btn-bg">🌗 背景切替</button>
  </div>

  <!-- Legends -->
  <div id="legends">
    <div class="legend-box" id="elev-legend">
      <span id="elev-min">0m</span>
      <div id="elev-gradient"></div>
      <span id="elev-max">—m</span>
    </div>
    <div class="legend-box" id="land-legend">
      🏘️ 土地利用：
      <div id="land-legend-items"></div>
    </div>
    <div class="legend-box" id="farm-legend">
      🌾 農地：
      <div id="farm-legend-items"></div>
    </div>
  </div>

  <div id="city-label"></div>

  <div id="info">
    <strong id="info-city">—</strong><br>
    <span id="info-road-line">道路数：<strong id="info-roads">—</strong><br></span>
    <span id="info-river-line" style="display:none">河川数：<strong id="info-rivers">—</strong><br></span>
    <span id="info-elev-line"  style="display:none">標高：<strong id="info-elev">—</strong><br></span>
    <span id="info-land-line"  style="display:none">土地利用：<strong id="info-land">—</strong><br></span>
    <span id="info-farm-line"  style="display:none">農地：<strong id="info-farm">—</strong><br></span>
    データ：OpenStreetMap / Open-Meteo
  </div>
</div>

<div id="toast"></div>

<script>
const canvas = document.getElementById('canvas');
const ctx    = canvas.getContext('2d');

// ══════════════════════════════════════════
//  State
// ══════════════════════════════════════════
const state = {
  roads: [], rivers: [], elevGrid: null, landPolys: [], farmPolys: [],
  cityName: '', bb: null,
  zoom: 1, panX: 0, panY: 0,
  dragging: false, dragStart: null,
  lineColor: '#c8c0ff',
  bgDark: true,
  // 各レイヤーのON/OFF（複数同時可）
  layers: { road: true, river: false, elev: false, land: false, farm: false },
};

// ══════════════════════════════════════════
//  土地利用カラーマップ
// ══════════════════════════════════════════
const LAND_COLORS_DARK = {
  residential:   'rgba(180,140,200,0.55)',
  commercial:    'rgba(255,180,80,0.55)',
  industrial:    'rgba(140,140,160,0.55)',
  retail:        'rgba(255,140,120,0.55)',
  farmland:      'rgba(160,210,120,0.45)',
  farm:          'rgba(160,210,120,0.45)',
  forest:        'rgba(40,140,80,0.60)',
  wood:          'rgba(40,140,80,0.60)',
  grass:         'rgba(120,200,100,0.50)',
  meadow:        'rgba(140,210,110,0.45)',
  park:          'rgba(80,190,120,0.55)',
  recreation_ground: 'rgba(100,200,130,0.50)',
  cemetery:      'rgba(160,190,160,0.50)',
  military:      'rgba(200,80,80,0.45)',
  education:     'rgba(100,160,240,0.50)',
  school:        'rgba(100,160,240,0.50)',
  hospital:      'rgba(240,120,140,0.55)',
  water:         'rgba(60,140,220,0.65)',
  reservoir:     'rgba(60,140,220,0.65)',
  quarry:        'rgba(160,130,100,0.55)',
  construction:  'rgba(220,180,80,0.45)',
  allotments:    'rgba(180,220,130,0.45)',
  orchard:       'rgba(160,220,100,0.45)',
  vineyard:      'rgba(200,180,100,0.45)',
  scrub:         'rgba(140,180,100,0.45)',
  heath:         'rgba(180,160,100,0.45)',
  _default:      'rgba(120,120,140,0.30)',
};
const LAND_COLORS_LIGHT = {
  residential:   'rgba(210,180,230,0.55)',
  commercial:    'rgba(255,210,130,0.60)',
  industrial:    'rgba(170,170,185,0.55)',
  retail:        'rgba(255,180,160,0.55)',
  farmland:      'rgba(200,240,160,0.55)',
  farm:          'rgba(200,240,160,0.55)',
  forest:        'rgba(80,180,100,0.55)',
  wood:          'rgba(80,180,100,0.55)',
  grass:         'rgba(160,230,130,0.50)',
  meadow:        'rgba(180,240,150,0.50)',
  park:          'rgba(120,220,160,0.55)',
  recreation_ground: 'rgba(140,230,170,0.50)',
  cemetery:      'rgba(190,210,190,0.55)',
  military:      'rgba(230,100,100,0.45)',
  education:     'rgba(140,190,255,0.55)',
  school:        'rgba(140,190,255,0.55)',
  hospital:      'rgba(255,160,170,0.55)',
  water:         'rgba(100,180,255,0.65)',
  reservoir:     'rgba(100,180,255,0.65)',
  quarry:        'rgba(190,160,130,0.55)',
  construction:  'rgba(250,220,100,0.50)',
  allotments:    'rgba(210,245,160,0.50)',
  orchard:       'rgba(200,250,130,0.50)',
  vineyard:      'rgba(235,215,130,0.50)',
  scrub:         'rgba(180,220,130,0.50)',
  heath:         'rgba(220,200,130,0.50)',
  _default:      'rgba(160,160,175,0.25)',
};

// 凡例用ラベル
const LAND_LABELS = {
  residential:'住宅地', commercial:'商業地', industrial:'工業地',
  retail:'商店街', farmland:'農地', farm:'農地', forest:'森林', wood:'森林',
  grass:'草地', meadow:'草地', park:'公園', recreation_ground:'公園',
  cemetery:'墓地', military:'軍事', education:'教育', school:'学校',
  hospital:'病院', water:'水域', reservoir:'貯水池', quarry:'採石場',
  construction:'建設中', allotments:'市民農園', orchard:'果樹園',
  vineyard:'ブドウ園', scrub:'低木', heath:'荒地',
};

// ══════════════════════════════════════════
//  Palette
// ══════════════════════════════════════════
const PALETTES = [
  {label:'紫光',color:'#c8c0ff'},{label:'白',color:'#ffffff'},
  {label:'黒',color:'#1a1a1a'},{label:'金',color:'#ffd97d'},
  {label:'珊瑚',color:'#ff6a9e'},{label:'翡翠',color:'#64ffda'},
  {label:'橙',color:'#ff9d5c'},{label:'青',color:'#60b0ff'},
];
PALETTES.forEach((p,i) => {
  const sw = document.createElement('div');
  sw.className = 'swatch'+(i===0?' active':'');
  sw.style.background = p.color; sw.title = p.label;
  sw.addEventListener('click', () => {
    document.querySelectorAll('.swatch').forEach(s=>s.classList.remove('active'));
    sw.classList.add('active'); state.lineColor = p.color; draw();
  });
  document.getElementById('color-row').appendChild(sw);
});

// ══════════════════════════════════════════
//  Layer toggles
// ══════════════════════════════════════════
document.querySelectorAll('.layer-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const layer = btn.dataset.layer;
    const nowOn = !state.layers[layer];
    state.layers[layer] = nowOn;
    btn.classList.toggle('on', nowOn);
    // 初めてONにしたときデータ取得
    if (nowOn && state.bb) {
      if (layer === 'river'  && state.rivers.length   === 0) fetchAndParseRivers();
      if (layer === 'elev'   && !state.elevGrid)             fetchElevation();
      if (layer === 'land'   && state.landPolys.length === 0) fetchLanduse();
      if (layer === 'farm'   && state.farmPolys.length  === 0) fetchFarm();
    }
    updateInfoPanel();
    updateLegends();
    draw();
  });
});

// ══════════════════════════════════════════
//  Canvas
// ══════════════════════════════════════════
function resize() { canvas.width=innerWidth; canvas.height=innerHeight; draw(); }
window.addEventListener('resize', resize); resize();

function draw() {
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle = state.bgDark ? '#0a0a0f' : '#f5f5f8';
  ctx.fillRect(0,0,W,H);

  const hasData = state.roads.length||state.rivers.length||state.elevGrid||state.landPolys.length;
  if (!hasData) { drawStars(W,H); return; }

  ctx.save();
  ctx.translate(W/2+state.panX, H/2+state.panY);
  ctx.scale(state.zoom, state.zoom);
  ctx.lineCap='round'; ctx.lineJoin='round';

  // 描画順：標高 → 土地利用 → 河川 → 道路
  if (state.layers.elev  && state.elevGrid)           drawElevation();
  if (state.layers.farm  && state.farmPolys.length)   drawFarm();
  if (state.layers.land  && state.landPolys.length)   drawLanduse();
  if (state.layers.river && state.rivers.length) {
    ctx.strokeStyle='#60b0ff'; ctx.lineWidth=1.4/state.zoom;
    ctx.shadowColor='#60b0ff'; ctx.shadowBlur=state.bgDark?4/state.zoom:0;
    drawLines(state.rivers);
  }
  if (state.layers.road  && state.roads.length) {
    ctx.strokeStyle=state.lineColor; ctx.lineWidth=0.8/state.zoom;
    ctx.shadowColor=state.lineColor; ctx.shadowBlur=state.bgDark?2/state.zoom:0;
    drawLines(state.roads);
  }
  ctx.restore();
}

function drawLines(segs) {
  ctx.shadowBlur = state.bgDark ? ctx.shadowBlur : 0;
  for (const seg of segs) {
    if (seg.length<2) continue;
    ctx.beginPath(); ctx.moveTo(seg[0].x,seg[0].y);
    for (let i=1;i<seg.length;i++) ctx.lineTo(seg[i].x,seg[i].y);
    ctx.stroke();
  }
}

// ── 標高ヒートマップ ──
function drawElevation() {
  const g = state.elevGrid;
  const {minE,maxE,rows,cols,cellW,cellH,totalW,totalH} = g;
  const range = maxE-minE||1;
  ctx.shadowBlur = 0;
  for (let r=0;r<rows;r++) {
    for (let c=0;c<cols;c++) {
      const t = (g.data[r][c]-minE)/range;
      const x = c*cellW - totalW/2;
      const y = r*cellH - totalH/2;
      ctx.fillStyle = elevColor(t,state.bgDark);
      ctx.fillRect(x,y,cellW+0.5,cellH+0.5);
    }
  }
}
function elevColor(t,dark) {
  const stops = dark
    ? [[0,[10,27,110]],[.15,[30,107,158]],[.30,[61,184,158]],[.45,[168,217,110]],
       [.60,[245,230,66]],[.75,[224,123,32]],[.90,[192,57,43]],[1,[240,230,220]]]
    : [[0,[170,210,255]],[.15,[120,200,180]],[.30,[90,190,110]],[.45,[190,210,80]],
       [.60,[230,200,60]],[.75,[200,140,60]],[.90,[160,80,40]],[1,[240,235,230]]];
  for (let i=0;i<stops.length-1;i++) {
    const [t0,c0]=stops[i],[t1,c1]=stops[i+1];
    if (t>=t0&&t<=t1) {
      const f=(t-t0)/(t1-t0);
      const r=Math.round(c0[0]+f*(c1[0]-c0[0]));
      const g=Math.round(c0[1]+f*(c1[1]-c0[1]));
      const b=Math.round(c0[2]+f*(c1[2]-c0[2]));
      return `rgba(${r},${g},${b},${dark?0.82:0.72})`;
    }
  }
  return 'rgba(240,230,220,0.8)';
}

// ── 土地利用ポリゴン ──
function drawLanduse() {
  ctx.shadowBlur = 0;
  const cmap = state.bgDark ? LAND_COLORS_DARK : LAND_COLORS_LIGHT;
  for (const poly of state.landPolys) {
    if (!poly.rings || poly.rings.length===0) continue;
    ctx.fillStyle = cmap[poly.type] || cmap._default;
    ctx.beginPath();
    // 外周
    const outer = poly.rings[0];
    if (outer.length<3) continue;
    ctx.moveTo(outer[0].x,outer[0].y);
    for (let i=1;i<outer.length;i++) ctx.lineTo(outer[i].x,outer[i].y);
    ctx.closePath();
    // 内側穴（関係ポリゴン等）
    for (let h=1;h<poly.rings.length;h++) {
      const hole=poly.rings[h];
      ctx.moveTo(hole[0].x,hole[0].y);
      for (let i=1;i<hole.length;i++) ctx.lineTo(hole[i].x,hole[i].y);
      ctx.closePath();
    }
    ctx.fill('evenodd');
  }
}

function drawStars(W,H) {
  ctx.fillStyle='rgba(200,192,255,0.4)';
  for (let i=0;i<120;i++){ctx.beginPath();ctx.arc(Math.random()*W,Math.random()*H,Math.random()*1.2,0,Math.PI*2);ctx.fill();}
}

// ══════════════════════════════════════════
//  Projection
// ══════════════════════════════════════════
function project(lat,lon,bb,scale) {
  return {
    x: (lon-bb.minLon)/(bb.maxLon-bb.minLon)*scale - scale/2,
    y:-((lat-bb.minLat)/(bb.maxLat-bb.minLat)*scale - scale/2),
  };
}
function getScale(bb) {
  const dLon=bb.maxLon-bb.minLon, dLat=bb.maxLat-bb.minLat;
  return dLon/dLat>canvas.width/canvas.height ? canvas.width*.88 : canvas.height*.88;
}

