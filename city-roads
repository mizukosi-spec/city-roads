// ── 土地利用 ──
async function fetchLanduse() {
  const bb=state.bb; const {minLat:s,minLon:w,maxLat:n,maxLon:e}=bb;
  showLoading(state.cityName,'土地利用データを取得中…',10);
  try {
    // landuse + natural + leisure をまとめて取得
    const q=`[out:json][timeout:90];
(
  way["landuse"](${s},${w},${n},${e});
  way["natural"~"wood|scrub|heath|grassland|wetland|water|beach"](${s},${w},${n},${e});
  way["leisure"~"park|garden|recreation_ground|golf_course|sports_centre"](${s},${w},${n},${e});
  way["amenity"~"school|university|hospital|cemetery"](${s},${w},${n},${e});
);
(._;>;);out body;`;
    setProgress(30);
    const data=await overpassFetch(q);
    setProgress(70);
    state.landPolys=parseLandPolys(data,bb);
    setProgress(100);
    updateInfoPanel(); updateLegends(); draw();
    toast(`土地利用 ${state.landPolys.length.toLocaleString()} 区画`);
  } catch(err){toast('土地利用エラー: '+err.message,5000);}
  finally{hideLoading();}
}

function parseLandPolys(data,bb) {
  const nodes={};
  for(const el of data.elements) if(el.type==='node') nodes[el.id]={lat:el.lat,lon:el.lon};
  const scale=getScale(bb); const polys=[];
  for(const el of data.elements){
    if(el.type!=='way') continue;
    const pts=[];
    for(const nid of el.nodes){const n=nodes[nid];if(n)pts.push(project(n.lat,n.lon,bb,scale));}
    if(pts.length<3) continue;
    // 閉じたwayのみ（ポリゴン）
    const first=el.nodes[0], last=el.nodes[el.nodes.length-1];
    if(first!==last) continue;
    // 土地利用タイプを決定
    const tags=el.tags||{};
    const type=tags.landuse||tags.natural||tags.leisure||tags.amenity||'_default';
    polys.push({type, rings:[pts]});
  }
  return polys;
}

// ── 標高 ──
async function fetchElevation() {
  const bb=state.bb;
  showLoading(state.cityName,'標高データを取得中…',10);
  try {
    const ROWS=10,COLS=10;
    const dLat=(bb.maxLat-bb.minLat)/(ROWS-1), dLon=(bb.maxLon-bb.minLon)/(COLS-1);
    const latArr=[],lonArr=[];
    for(let r=0;r<ROWS;r++) for(let c=0;c<COLS;c++){
      latArr.push((bb.minLat+r*dLat).toFixed(5));
      lonArr.push((bb.minLon+c*dLon).toFixed(5));
    }
    setProgress(30);
    const url=`https://api.open-meteo.com/v1/elevation?latitude=${latArr.join(',')}&longitude=${lonArr.join(',')}`;
    const res=await fetch(url); if(!res.ok) throw new Error('Open-Meteo HTTP '+res.status);
    const json=await res.json(); const flat=json.elevation;
    setProgress(80);
    const data2d=[];
    for(let r=0;r<ROWS;r++){const row=[];for(let c=0;c<COLS;c++)row.push(flat[r*COLS+c]);data2d.push(row);}
    data2d.reverse();
    const all=flat.filter(v=>v!=null);
    const minE=Math.round(Math.min(...all)), maxE=Math.round(Math.max(...all));
    const scale=getScale(bb);
    state.elevGrid={data:data2d,rows:ROWS,cols:COLS,minE,maxE,cellW:scale/COLS,cellH:scale/ROWS,totalW:scale,totalH:scale};
    document.getElementById('elev-min').textContent=minE+'m';
    document.getElementById('elev-max').textContent=maxE+'m';
    updateInfoPanel(); updateLegends(); draw();
    toast(`標高 ${minE}m〜${maxE}m`);
  } catch(err){toast('標高エラー: '+err.message,5000);}
  finally{hideLoading();}
}

